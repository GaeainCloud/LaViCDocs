# SmartOKR MCP Server Configuration

# Data directory for OKR definitions, evidence, and scores
# Default: ./data (relative to SmartOKR/)
SMARTOKR_DATA_DIR=./data

# GitHub Integration
# Personal access token for GitHub API (required for private repos)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Default GitHub owner/org (optional, can be overridden per tool call)
GITHUB_DEFAULT_OWNER=

# Default GitHub repository (optional)
GITHUB_DEFAULT_REPO=

# Get笔记知识库 Integration
# API Base URL
GETNOTE_API_BASE=https://open-api.biji.com/getnote/openapi
# Knowledge base topic ID
GETNOTE_TOPIC_ID=rYMVXjK0
# API Key (Bearer token)
GETNOTE_API_KEY=B6Xec+VklOztQvKhIIZicViWUlXlV6lrxvoXixA9j5OL1Io4XyOHwUDAUbRY3f9A2rj/YSpeINxUqwIiyeJ9F+7LvuJiv4SeaZtt

# Logging level
LOG_LEVEL=INFO
